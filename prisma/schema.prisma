generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  intern
  manager
  org_admin
}

enum Provider {
  github
  gitlab
}

enum ActivityType {
  commit
  pr_opened
  pr_merged
  pr_closed
  review
  issue_opened
  issue_closed
  comment
}

model User {
  id                  String    @id @default(cuid())
  email               String?   @unique
  name                String?
  image               String?
  githubId            String?   @unique
  githubUsername      String?
  role                Role      @default(intern)
  internshipStartDate DateTime?
  internshipEndDate   DateTime?
  createdAt           DateTime  @default(now())

  accounts       Account[]
  sessions       Session[]
  repoSelections RepoSelection[]
  activityEvents ActivityEvent[]
  standupDocs    StandupDoc[]
  managerInvites ManagerInvite[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  // OAuth access token, AES-256-GCM encrypted at rest (src/lib/crypto.ts)
  access_token      String?
  refresh_token     String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RepoSelection {
  id           String    @id @default(cuid())
  userId       String
  provider     Provider  @default(github)
  owner        String
  name         String
  fullName     String
  githubRepoId String
  private      Boolean   @default(false)
  included     Boolean   @default(false)
  lastSyncedAt DateTime?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityEvents ActivityEvent[]

  @@unique([userId, provider, githubRepoId])
}

model ActivityEvent {
  id           String       @id @default(cuid())
  userId       String
  repoId       String
  provider     Provider     @default(github)
  externalId   String
  type         ActivityType
  title        String
  summary      String?
  url          String
  additions    Int?
  deletions    Int?
  filesChanged Int?
  occurredAt   DateTime
  rawJson      Json?

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo RepoSelection @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@index([userId, occurredAt])
}

model StandupDoc {
  id          String   @id @default(cuid())
  userId      String
  rangeStart  DateTime
  rangeEnd    DateTime
  tone        String
  length      String
  contentMd   String
  contentJson Json?
  eventIds    String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ManagerInvite {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  email     String?
  expiresAt DateTime?
  revokedAt DateTime?
  // permissions: which repos + earliest date the manager may see
  repoScope String[]
  dateFloor DateTime?
  createdAt DateTime  @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes ManagerNote[]
}

model ManagerNote {
  id        String   @id @default(cuid())
  inviteId  String
  body      String
  createdAt DateTime @default(now())

  invite ManagerInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
}
