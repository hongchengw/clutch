# PostgreSQL connection string (Neon/Supabase/local)
DATABASE_URL="postgresql://user:password@localhost:5432/shiplog"

# GitHub OAuth app credentials (https://github.com/settings/developers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Auth.js session secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# 32-byte base64 key for encrypting OAuth tokens at rest — generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=""

# Optional: AI provider key for standup narration (template fallback used when absent)
AI_API_KEY=""
