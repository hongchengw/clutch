# Database (Neon / Supabase / local Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/shiplog?sslmode=require"

# Auth.js / NextAuth (Person A)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
GITHUB_ID=""
GITHUB_SECRET=""

# Token encryption at rest (Person A)
TOKEN_ENCRYPTION_KEY=""

# AI standup generation (Person B) — optional; template fallback works without it
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
